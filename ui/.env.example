# Copy this to ui/.env (or ui/.env.local) and override per deployment.
# Vite inlines VITE_* vars at BUILD time — change requires a rebuild.

# WebSocket endpoint the dashboard + arcade connect to. Default
# `ws://localhost:8787` matches `npm run server` for local dev.
# For the public VPS deploy, point at the reverse-proxied wss endpoint, e.g.:
# VITE_WS_URL=wss://sealedbid.liquidated.xyz/ws
VITE_WS_URL=ws://localhost:8787
